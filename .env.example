# ─── Server ────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce_db?schema=public"

# ─── Security ──────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Logging ───────────────────────────────────────────
LOG_LEVEL=info

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
